// BenchmarkStructToMapGDB 测试 StructToMap 性能
func BenchmarkStructToMapGDB(b *testing.B) {
	_, structs, _ := prepareTestData(1)

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		_, _ = gdb.StructToMap(structs[0])
	}
}

// BenchmarkStructToMapJSON 测试 JSON Marshal + 转换为map性能
func BenchmarkStructToMapJSON(b *testing.B) {
	_, structs, _ := prepareTestData(1)

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		jsonBytes, _ := json.Marshal(structs[0])
		var m map[string]any
		_ = json.Unmarshal(jsonBytes, &m)
	}
}


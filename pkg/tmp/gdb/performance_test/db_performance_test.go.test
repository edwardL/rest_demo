// BenchmarkGormSelectSingle GORM单条查询性能测试
func BenchmarkGormSelectSingle(b *testing.B) {
	if err := createTestData(); err != nil {
		b.Fatal("Failed to create test data:", err)
	}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		var user UserPerformanceTest
		result := gormDB.First(&user, i%10000+1) // 使用更大的ID范围
		if result.Error != nil && result.Error != gorm.ErrRecordNotFound {
			b.Fatal("GORM single query failed:", result.Error)
		}
	}
}

// BenchmarkGdbSelectSingle GDB单条查询性能测试
func BenchmarkGdbSelectSingle(b *testing.B) {
	if err := createTestData(); err != nil {
		b.Fatal("Failed to create test data:", err)
	}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		var user UserPerformanceTest
		err := gdb.New("users_performance_test").Where("id = ?", i%10000+1).One(&user).Error // 使用更大的ID范围
		if err != nil {
			b.Fatal("GDB single query failed:", err)
		}
	}
}

// BenchmarkGormUpdate GORM更新性能测试
func BenchmarkGormUpdate(b *testing.B) {
	if err := createTestData(); err != nil {
		b.Fatal("Failed to create test data:", err)
	}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		userID := i%10000 + 1 // 使用更大的ID范围
		result := gormDB.Model(&UserPerformanceTest{}).Where("id = ?", userID).Update("name", fmt.Sprintf("UpdatedUser_%d", userID))
		if result.Error != nil {
			b.Fatal("GORM update failed:", result.Error)
		}
	}
}

// BenchmarkGdbUpdate GDB更新性能测试
func BenchmarkGdbUpdate(b *testing.B) {
	if err := createTestData(); err != nil {
		b.Fatal("Failed to create test data:", err)
	}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		userID := i%10000 + 1 // 使用更大的ID范围
		err := gdb.New("users_performance_test").Where("id = ?", userID).Update("name", fmt.Sprintf("UpdatedUser_%d", userID)).Error
		if err != nil {
			b.Fatal("GDB update failed:", err)
		}
	}
}

// BenchmarkGormInsert GORM插入性能测试
func BenchmarkGormInsert(b *testing.B) {
	if err := createTestData(); err != nil {
		b.Fatal("Failed to create test data:", err)
	}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		user := UserPerformanceTest{
			Name:     fmt.Sprintf("InsertUser_%d", i),
			Age:      20 + (i % 40),
			Email:    fmt.Sprintf("insert%d@example.com", i),
			Active:   true,
			CreateTs: time.Now().Unix(),
		}
		result := gormDB.Create(&user)
		if result.Error != nil {
			b.Fatal("GORM insert failed:", result.Error)
		}
		// 删除插入的数据，避免后续测试冲突
		gormDB.Delete(&user)
	}
}

// BenchmarkGdbInsert GDB插入性能测试
func BenchmarkGdbInsert(b *testing.B) {
	if err := createTestData(); err != nil {
		b.Fatal("Failed to create test data:", err)
	}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		user := UserPerformanceTest{
			Name:     fmt.Sprintf("InsertUser_%d", i),
			Age:      20 + (i % 40),
			Email:    fmt.Sprintf("insert%d@example.com", i),
			Active:   true,
			CreateTs: time.Now().Unix(),
		}
		err := gdb.New("users_performance_test").Create(user).Error
		if err != nil {
			b.Fatal("GDB insert failed:", err)
		}
		// 删除插入的数据，避免后续测试冲突
		gdb.New("users_performance_test").Where("name = ?", user.Name).Delete()
	}
}

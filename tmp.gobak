// 生成16位MD5哈希值
func Md516(s string) string {
	// 先计算32位MD5
	h := md5.New()
	h.Write([]byte(s))
	// 转换为16进制字符串
	md5Str := hex.EncodeToString(h.Sum(nil))
	// 取中间16位（8-24位）
	return md5Str[8:24]
}

func md532(s string) string {
	// 先计算32位MD5
	h := md5.New()
	h.Write([]byte(s))
	// 转换为16进制字符串
	md5Str := hex.EncodeToString(h.Sum(nil))
	return md5Str
}

type captchaReqItem struct {
	Rndtext string `json:"rndtext"` //生成的随机文本
}

// 验证请求req
type captchaReq struct {
	Data []captchaReqItem `json:"data"`
}

type LoginReqItem struct {
	UserTs      string `json:"user_ts"`      // 默认写死1
	UserName    string `json:"user_name"`    // 用户名
	UserPass    string `json:"user_pass"`    // 加密的密码
	UserCaptcha string `json:"user_captcha"` // 验证码
	LoginForce  string `json:"login_force"`  //
}

// 登录请求Req
type LoginReq struct {
	Data []LoginReqItem `json:"data"`
}

func main() {
	// 请求者随机生成6位字符串,rndOrig 如ajdfgk
	rndOrig := "ajdfgk"
	reqIP := "10.8.0.33"
	accessKey := "AiclrSlno8c/UxF"
	// 根据请求IP reqIP与对接密钥secKey(对接密钥联系我们获取) 形成原始字符串 reqIP_secKey  如10.10.10.2_XXXXXX
	reqIP_secKey := reqIP + "_" + accessKey
	// 计算第二步MD5值 MD5("10.10.10.2_XXXXXX") 得出加密密钥
	key := md532(reqIP_secKey)
	fmt.Println("md5 key ", key)

	finalRndText := hex.EncodeToString([]byte(SitkAesEncrypt([]byte(key), []byte(rndOrig))))
	fmt.Println("captcha 传参", finalRndText)

	// 2. 创建带 CookieJar 的 HTTP 客户端（核心：自动管理 Cookie）
	// cookiejar 会自动保存所有接口返回的 Cookie，后续请求同一域名时自动携带
	// 别的语言估计需要先获取captcha reponse 的cookie, 后面需要设置在login 接口的cookie 请求
	jar, err := cookiejar.New(nil)
	if err != nil {
		log.Fatalf("创建 CookieJar 失败：%v", err)
	}

	client := &http.Client{
		Timeout: 5 * time.Second,
		Jar:     jar, // 启用 Cookie 自动管理
	}
	reqParam := captchaReq{
		Data: []captchaReqItem{
			{Rndtext: finalRndText},
		}}
	jsonData, _ := json.Marshal(reqParam)
	// 2. 构建请求体（字节缓冲区）
	reqBody := bytes.NewBuffer(jsonData)
	// 3. 创建 POST 请求，指定 content-type 为 application/json
	req, err := http.NewRequest("POST", "http://192.168.168.168:8224/users/u/captcha4other", reqBody)
	if err != nil {
		fmt.Printf("创建请求失败：%v\n", err)
		return
	}
	req.Header.Set("Content-Type", "application/json") // 关键：告诉服务端是 JSON 格式
	// 4. 发送请求
	resp, err := client.Do(req)
	if err != nil {
		fmt.Printf("POST JSON 失败：%v\n", err)
		return
	}
	defer resp.Body.Close()

	// 5. 处理响应
	body, _ := ioutil.ReadAll(resp.Body)
	fmt.Printf("JSON 响应：%s\n", body)

	// 处理结果
	encoded := strings.ReplaceAll(string(body), "data:image/jpeg;base64,", "")

	decoded, err := base64.StdEncoding.DecodeString(encoded)
	if err != nil {
		log.Fatal("解码错误:", err)
	}

	decyptText := decoded[len(decoded)-304 : len(decoded)-32] // 取最末位304字节，其中前272字节为加密证书，后32字节为验证码加密串
	decyptVerifyCode := decoded[len(decoded)-32:]
	//hexDecodedString, err := hex.DecodeString(string(decyptKey)) // 解码第三步
	//fmt.Println("验证码加密串: ", hexDecodedString)                    // 验证码加密串
	fmt.Println("加密证书: 开头有换行符: ", string(decyptText)) // 加密证书

	// 从 captcha 接口获取cookie
	// 需要从captcha 接口获取cookie ， 设置到 login 接口中
	//rndOrig_reqIP := rndOrig + "_" + reqIP
	//decodeKey := Md516(rndOrig_reqIP)
	//fmt.Println("16位md5 ", decodeKey)
	// 利用第5步的密钥通过AES将第3步解码串进行解密，得到最终的验证码
	//verifyCodeKey := rndOrig + "_" + reqIP
	rndOrig_reqIP := rndOrig + "_" + reqIP
	//decodeKey := Md516(rndOrig_reqIP) // md5 hash16byte 转16进制32字符串 取 8-24
	decodeKey := rndOrig_reqIP
	verifyCode := SitkAesDecrypt(decyptVerifyCode, []byte(decodeKey))
	fmt.Println("verifyCode: ", hex.EncodeToString([]byte(verifyCode)))

	// 通过证书加密登录密码
	publicKey, err := extractRASPublicKeyFromContent(decyptText)
	if err != nil {
		fmt.Println(err)
	}
	fmt.Println("=== Go Public Key ===")
	fmt.Printf("Modulus: %x\n", publicKey.N)
	fmt.Printf("Exponent: %x\n", publicKey.E)
	// 用公钥加密密码
	cipherText, err := encryptPasswordWithPublicKey(publicKey, "edward") // 用户密码
	if err != nil {
		fmt.Printf("加密密码失败：%v\n", err)
		return
	}
	fmt.Println("cipherText", cipherText)
	cipherTextEncode64 := base64.StdEncoding.EncodeToString(cipherText)
	fmt.Println("cipherTextEncode64", cipherTextEncode64)

	var loginReq = LoginReq{
		Data: []LoginReqItem{
			{
				UserTs:      "1",
				UserName:    "edward", // 用户名
				UserPass:    cipherTextEncode64,
				UserCaptcha: "1234",
				LoginForce:  "0",
			},
		},
	}
	jsonData, _ = json.Marshal(loginReq)
	reqBody = bytes.NewBuffer(jsonData)
	// 2. 构建请求体（字节缓冲区）
	reqBody = bytes.NewBuffer(jsonData)
	// 3. 创建 POST 请求，指定 content-type 为 application/json
	req, err = http.NewRequest("POST", "http://192.168.168.168:8224/users/u/login", reqBody)
	if err != nil {
		fmt.Printf("创建请求失败：%v\n", err)
		return
	}
	req.Header.Set("Content-Type", "application/json") // 关键：告诉服务端是 JSON 格式
	// 4. 发送请求
	resp, err = client.Do(req)
	if err != nil {
		fmt.Printf("POST JSON 失败：%v\n", err)
		return
	}
	defer resp.Body.Close()

	// 5. 处理响应
	body, _ = ioutil.ReadAll(resp.Body)
	fmt.Printf("JSON 响应：%s\n", body)
	// 解析返回的json 字符串 可以拿到 user_id , user_ts, user_token 作为接口header 参数
	// {"result":true,"code":"0000","data":[{"user_ts":"1","user_id":"19000021","user_type":"0","user_name":"ludehua","user_org":"4000112","user_role":"5","user_ts_lst":"1","user_token":"","user_pwd_expiration":"90","user_orgs":{"1":{"belong_orgs":"4000112","under_orgs":"4000112,16000005-16000008"}},"user_roles":{"1":"5"},"menu_url":"/menu/u/getmenu","lock_screentime":0},{"need_show_license_expir_info":0,"agent_license_status":1,"agent_license_expired":"2026-10-01 00:00:00","agent_license_reamin_days":314,"scan_license_status":1,"scan_license_expired":"2124-09-25 23:59:59","scan_license_reamin_days":36103}],"msg":"操作成功! "}
}

func extractRASPublicKeyFromContent(keyBytes []byte) (*rsa.PublicKey, error) {
	block, _ := pem.Decode(keyBytes)
	if block == nil {
		return nil, fmt.Errorf("无效的 PEM 格式公钥")
	}
	if block.Type != "PUBLIC KEY" {
		return nil, fmt.Errorf("PEM 块类型不是裸公钥（实际：%s）", block.Type)
	}

	// 3. 解析 PKCS#8 格式公钥（裸公钥默认是 PKCS#8 标准）
	publicKeyInterface, err := x509.ParsePKIXPublicKey(block.Bytes)
	if err != nil {
		return nil, fmt.Errorf("解析公钥失败：%w", err)
	}

	// 4. 断言公钥为 RSA 类型
	publicKey, ok := publicKeyInterface.(*rsa.PublicKey)
	if !ok {
		return nil, fmt.Errorf("公钥不是 RSA 类型（实际：%T）", publicKeyInterface)
	}
	return publicKey, nil
}

// 固定随机数生成器（仅用于测试！）
// 种子固定为 1024，确保每次运行生成相同的随机填充，相同明文得到相同密文
var fixedRand = func() *mathRand.Rand {
	seed := int64(1024) // 固定种子，可修改为任意固定值
	return mathRand.New(mathRand.NewSource(seed))
}()

// 用 RSA 公钥加密密码（PKCS1v15 填充，适用于短数据如密码）
func encryptPasswordWithPublicKey(publicKey *rsa.PublicKey, password string) ([]byte, error) {
	// 密码转字节流
	passwordBytes := []byte(password)

	// 校验密码长度（避免超过 RSA 单次加密限制）
	maxEncryptLen := publicKey.Size() - 11 // PKCS1v15 填充占用 11 字节
	if len(passwordBytes) > maxEncryptLen {
		return nil, fmt.Errorf("密码过长（最大支持 %d 字节，当前 %d 字节）", maxEncryptLen, len(passwordBytes))
	}
	// RSA 公钥加密（使用随机数生成器确保加密安全性）
	cipherText, err := rsa.EncryptPKCS1v15(fixedRand, publicKey, passwordBytes)
	if err != nil {
		return nil, fmt.Errorf("RSA 加密失败：%w", err)
	}

	return cipherText, nil
}

func SitkAesEncrypt(key []byte, data []byte) (tk string) {
	var md5cipher string
	defer func() {
		if err := recover(); err != nil {
			tk = ""
		}
	}()

	if len(data) == 0 {
		return ""
	}
	md5cipher = fmt.Sprintf("%x", md5.Sum(key))
	block, err := aes.NewCipher([]byte(md5cipher))
	if err != nil {
		return ""
	}
	//判断加密快的大小
	blockSize := block.BlockSize()
	//填充
	encryptBytes := pkcs7Padding(data, blockSize)
	//初始化加密数据接收切片
	crypted := make([]byte, len(encryptBytes))
	//使用cbc加密模式
	blockMode := cipher.NewCBCEncrypter(block, key[:blockSize])
	//执行加密
	blockMode.CryptBlocks(crypted, encryptBytes)
	return string(crypted)
}

// pkcs7Padding 填充
func pkcs7Padding(data []byte, blockSize int) []byte {
	//判断缺少几位长度。最少1，最多 blockSize
	padding := blockSize - len(data)%blockSize
	//补足位数。把切片[]byte{byte(padding)}复制padding个
	padText := bytes.Repeat([]byte{byte(padding)}, padding)
	return append(data, padText...)
}

// pkcs7UnPadding 填充的反向操作
func pkcs7UnPadding(data []byte) ([]byte, error) {
	length := len(data)
	if length == 0 {
		return nil, errors.New("加密字符串错误！")
	}
	//获取填充的个数
	unPadding := int(data[length-1])
	if (length - unPadding) < 0 {
		return data, nil
	} else {
		return data[:(length - unPadding)], nil
	}
}

func SitkAesDecrypt(data []byte, key []byte) string {
	//创建实例
	var md5cipher string
	if len(data) == 0 {
		return ""
	}
	md5cipher = fmt.Sprintf("%x", md5.Sum(key))
	block, err := aes.NewCipher([]byte(md5cipher))
	if err != nil {
		return ""
	}
	//获取块的大小
	blockSize := block.BlockSize()
	//使用cbc
	blockMode := cipher.NewCBCDecrypter(block, key[:blockSize])
	//初始化解密数据接收切片
	crypted := make([]byte, len(data))
	//执行解密
	blockMode.CryptBlocks(crypted, data)
	//去除填充
	crypted, err = pkcs7UnPadding(crypted)
	if err != nil {
		return ""
	}
	return string(crypted)
}

func main2() {
	rndText := "ajdfgk"
	ip := "10.10.10.2"
	encoded := ""
	decoded, err := base64.StdEncoding.DecodeString(encoded)
	if err != nil {
		log.Fatal("解码错误:", err)
	}
	// fmt.Printf("解码结果: %s\n", decoded) // Hello, World!
	decyptText := decoded[len(decoded)-303 : len(decoded)-32]
	hexDecodedString, err := hex.DecodeString(string(decoded[len(decoded)-32:]))

	fmt.Println(hexDecodedString)
	fmt.Println(string(decyptText))

	keyStr := fmt.Sprintf("%s_%s", rndText, ip)

	key := Md516(keyStr)
	//
	fmt.Println(key)

	finalText := SitkAesDecrypt(hexDecodedString, []byte(key))
	fmt.Println(finalText)
}
